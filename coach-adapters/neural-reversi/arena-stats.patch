+    /// Auto-detect: if the stream starts with zstd magic (0x28 0xB5 0x2F 0xFD), decompress.
+    /// Otherwise read raw binary directly (pre-decompressed by coach-build).
+    fn from_reader<R: Read>(mut reader: R) -> io::Result<Self> {
+        // Peek at first 4 bytes to detect zstd magic
+        let mut magic = [0u8; 4];
+        let n = reader.read(&mut magic)?;
+        // Reconstruct a reader that includes the peeked bytes
+        let full_reader = std::io::Cursor::new(magic[..n].to_vec()).chain(reader);
+        if &magic == b"\x28\xB5\x2F\xFD" {
+            // Zstd compressed — wrap in decoder
+            let decoder = zstd::stream::read::Decoder::new(full_reader)?;
+            Self::from_raw_reader(decoder)
+        } else {
+            // Raw binary (pre-decompressed)
+            Self::from_raw_reader(full_reader)
+        }
+    }
+
+    fn from_raw_reader<R: Read>(mut reader: R) -> io::Result<Self> {
+        let base_input = BaseInput::load(&mut reader)?;
+        let pa_input = PhaseAdaptiveInput::load(&mut reader)?;
+        let layer_stacks = Self::load_layer_stacks(&mut reader)?;
